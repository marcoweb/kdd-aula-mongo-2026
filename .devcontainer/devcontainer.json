{
  "name": "Python + Jupyter",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [8888, 27017],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        "jupyter.askForKernelRestart": false
      }
    }
  },
  "postCreateCommand": "pip install --no-cache-dir jupyter ipykernel pymongo pandas matplotlib"
}